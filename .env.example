# Antariksh V1 Environment Variables
# These keys are useful if some inference APIs require authentication.
# Since we are running primarily on Kaggle, Kaggle secrets may be used instead.

# Optional: Add OpenRouter API key if you plan to hit them via API
OPENROUTER_API_KEY=your_key_here

# Optional: Remote endpoint config
REMOTE_INFERENCE_URL=http://your_kaggle_endpoint
